@page
@model YukiSoraShop.Pages.Customer.RegisterShopModel
@{
    ViewData["Title"] = "Đăng ký Shop";
}

<div class="container py-4">
    <h2 class="mb-4"><i class="fas fa-store me-2"></i>Đăng ký Shop</h2>

    @if (Model.HasShop && Model.ExistingShop != null)
    {
        <div class="alert alert-success">
            <h5><i class="fas fa-check-circle me-2"></i>Shop của bạn đã được duyệt!</h5>
            <p class="mb-1"><strong>Tên shop:</strong> @Model.ExistingShop.ShopName</p>
            <p class="mb-2"><strong>Trạng thái:</strong> <span class="badge bg-success">Đang hoạt động</span></p>
            <a asp-page="/Customer/MyShop" class="btn btn-primary">
                <i class="fas fa-cog me-1"></i> Quản lý Shop
            </a>
        </div>
    }
    else if (Model.HasPendingApplication)
    {
        <div class="alert alert-warning">
            <h5><i class="fas fa-clock me-2"></i>Đơn đăng ký đang chờ duyệt</h5>
            <p>Bạn đã gửi đơn đăng ký shop. Vui lòng chờ admin duyệt.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-file-alt me-2"></i>Thông tin đăng ký Shop</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label asp-for="ShopName" class="form-label fw-bold">Tên Shop <span class="text-danger">*</span></label>
                        <input asp-for="ShopName" class="form-control" placeholder="Nhập tên shop của bạn" />
                        <span asp-validation-for="ShopName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả về shop của bạn..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PhoneNumber" class="form-label fw-bold">Số điện thoại</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="0123456789" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Address" class="form-label fw-bold">Địa chỉ</label>
                            <input asp-for="Address" class="form-control" placeholder="Địa chỉ shop" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-paper-plane me-1"></i> Gửi đơn đăng ký
                    </button>
                </form>
            </div>
        </div>
    }

    @if (Model.MyApplications.Any())
    {
        <div class="card shadow-sm mt-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-history me-2"></i>Lịch sử đơn đăng ký</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tên Shop</th>
                            <th>Ngày gửi</th>
                            <th>Trạng thái</th>
                            <th>Ghi chú</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model.MyApplications)
                        {
                            <tr>
                                <td>@app.ShopName</td>
                                <td>@app.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @switch (app.Status)
                                    {
                                        case Domain.Enums.ShopApplicationStatus.Pending:
                                            <span class="badge bg-warning text-dark">Đang chờ</span>
                                            break;
                                        case Domain.Enums.ShopApplicationStatus.Approved:
                                            <span class="badge bg-success">Đã duyệt</span>
                                            break;
                                        case Domain.Enums.ShopApplicationStatus.Rejected:
                                            <span class="badge bg-danger">Từ chối</span>
                                            break;
                                    }
                                </td>
                                <td>@(app.AdminNote ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
