@page "/Customer/Cart"
@model YukiSoraShop.Pages.Customer.CustomerCartModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="commerce-hero compact mb-4">
    <div>
        <span class="commerce-eyebrow">Giỏ hàng</span>
        <h1>Giỏ hàng của bạn</h1>
        <p>Quản lý sản phẩm yêu thích và tiến hành thanh toán nhanh chóng.</p>
    </div>
</div>

<div class="row g-4">
    @if (Model.CartItems.Any())
        {
                <!-- LEFT: CART ITEMS -->
                <div class="col-lg-8">
                    @foreach (var item in Model.CartItems)
                    {
                        <div class="card border-0 shadow-sm mb-4 hover-lift rounded-4">
                            <div class="card-body d-flex align-items-center justify-content-between flex-wrap">
                                <div class="d-flex align-items-center">
                                    <img src="@item.Product.ImageUrl" alt="@item.Product.Name"
                                         class="rounded-3 me-3"
                                         style="width: 96px; height: 96px; object-fit: cover;">
                                    <div>
                                        <h6 class="fw-bold mb-1 text-dark">@item.Product.Name</h6>
                                        <p class="text-muted small mb-2">@item.Product.Category</p>
                                        <span class="fw-semibold">@item.Product.Price.ToString("N0") VNĐ</span>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center gap-3 mt-3 mt-md-0">
                                    <form method="post" asp-page-handler="UpdateQuantity" class="d-inline">
                                        <input type="hidden" name="productId" value="@item.Product.Id" />
                                        <div class="input-group input-group-sm">
                                            <button type="submit" name="action" value="decrease" class="btn btn-outline-secondary">−</button>
                                            <input type="text" readonly class="form-control text-center" value="@item.Quantity" />
                                            <button type="submit" name="action" value="increase" class="btn btn-outline-secondary">+</button>
                                        </div>
                                    </form>

                                    <div class="text-end">
                                        <div class="fw-bold">@item.TotalPrice.ToString("N0") VNĐ</div>
                                    </div>

                                    <form method="post" asp-page-handler="RemoveItem" class="d-inline">
                                        <input type="hidden" name="productId" value="@item.Product.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle"
                                                title="Xóa sản phẩm"
                                                onclick="return confirm('Xóa sản phẩm này khỏi giỏ hàng?')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- RIGHT: ORDER SUMMARY -->
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body">
                            <h5 class="fw-bold mb-4"><i class="fas fa-receipt me-2"></i>Tổng quan đơn hàng</h5>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Tạm tính:</span>
                                <span>@Model.TotalAmount.ToString("N0") VNĐ</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Vận chuyển:</span>
                                <span class="text-success">Miễn phí</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Thuế (10%):</span>
                                <span>@((Model.TotalAmount * 0.1m).ToString("N0")) VNĐ</span>
                            </div>
                            <hr>
                            <div class="d-flex justify-content-between mb-4">
                                <strong>Tổng cộng:</strong>
                                <strong>@((Model.TotalAmount * 1.1m).ToString("N0")) VNĐ</strong>
                            </div>

                            @if (!Model.CanCheckout)
                            {
                                <div class="alert alert-warning">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    <small>Tài khoản quản trị/nhân viên không thể đặt hàng.</small>
                                </div>
                                <button type="button" class="btn btn-secondary w-100 py-2 fw-semibold" disabled>
                                    <i class="fas fa-ban me-2"></i> Không thể thanh toán
                                </button>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="Checkout">
                                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                                        <i class="fas fa-credit-card me-2"></i> Thanh toán ngay
                                    </button>
                                </form>
                            }

                            <a href="/Customer/Catalog" class="btn btn-outline-secondary w-100 mt-3">
                                <i class="fas fa-arrow-left me-2"></i> Tiếp tục mua hàng
                            </a>
                        </div>
                    </div>
                </div>
        }
        else
        {
            <div class="col-12">
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="fas fa-shopping-cart"></i></div>
                    <div class="empty-state-title">Giỏ hàng trống</div>
                    <p class="empty-state-message">Hãy chọn vài sản phẩm yêu thích để thêm vào giỏ hàng nhé!</p>
                    <a href="/Customer/Catalog" class="btn btn-primary px-4 py-2 fw-semibold">
                        <i class="fas fa-store me-2"></i> Khám phá sản phẩm
                    </a>
                </div>
            </div>
        }
</div>
