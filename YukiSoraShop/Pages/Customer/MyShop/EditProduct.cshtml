@page "{id:int}"
@model YukiSoraShop.Pages.Customer.MyShop.EditProductModel
@{
    ViewData["Title"] = "Sửa sản phẩm";
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Customer/MyShop">Shop của tôi</a></li>
            <li class="breadcrumb-item active">Sửa sản phẩm</li>
        </ol>
    </nav>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Sửa sản phẩm</h5>
        </div>
        <div class="card-body">
            <form method="post">
                <input type="hidden" asp-for="Product.Id" />
                <input type="hidden" asp-for="Product.ShopId" />
                <div class="mb-3">
                    <label asp-for="Product.ProductName" class="form-label fw-bold">Tên sản phẩm <span class="text-danger">*</span></label>
                    <input asp-for="Product.ProductName" class="form-control" />
                    <span asp-validation-for="Product.ProductName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Product.Description" class="form-label fw-bold">Mô tả</label>
                    <textarea asp-for="Product.Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Product.Description" class="text-danger"></span>
                </div>
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Product.Price" class="form-label fw-bold">Giá (₫) <span class="text-danger">*</span></label>
                        <input asp-for="Product.Price" class="form-control" type="number" step="1000" min="1" />
                        <span asp-validation-for="Product.Price" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Product.StockQuantity" class="form-label fw-bold">Số lượng tồn kho <span class="text-danger">*</span></label>
                        <input asp-for="Product.StockQuantity" class="form-control" type="number" min="1" />
                        <span asp-validation-for="Product.StockQuantity" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Product.CategoryId" class="form-label fw-bold">Danh mục <span class="text-danger">*</span></label>
                        <select asp-for="Product.CategoryId" asp-items="Model.CategoryOptions" class="form-select">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                        <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i> Lưu thay đổi
                    </button>
                    <a asp-page="/Customer/MyShop" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
