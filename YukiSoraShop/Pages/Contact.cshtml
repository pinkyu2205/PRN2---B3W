@page
@{
    ViewData["Title"] = "Liên hệ";
}

<section class="commerce-hero compact">
    <div>
        <span class="commerce-eyebrow">Hỗ trợ khách hàng</span>
        <h1>Liên hệ YukiSora</h1>
        <p>Đội ngũ tư vấn luôn sẵn sàng hỗ trợ đơn hàng, bảo hành và giải pháp công nghệ cho doanh nghiệp.</p>
    </div>
</section>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="commerce-panel h-100">
            <h2 class="section-title">Gửi yêu cầu hỗ trợ</h2>
            <form class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Họ và tên</label>
                    <input class="form-control" placeholder="Nguyễn Văn A" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Số điện thoại</label>
                    <input class="form-control" placeholder="090..." />
                </div>
                <div class="col-12">
                    <label class="form-label">Email</label>
                    <input class="form-control" type="email" placeholder="you@example.com" />
                </div>
                <div class="col-12">
                    <label class="form-label">Nội dung</label>
                    <textarea class="form-control" rows="5" placeholder="Bạn cần hỗ trợ vấn đề gì?"></textarea>
                </div>
                <div class="col-12">
                    <button type="button" class="btn btn-commerce-primary">
                        <i class="fas fa-paper-plane me-2"></i>Gửi liên hệ
                    </button>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="commerce-panel h-100">
            <h2 class="section-title">Thông tin liên hệ</h2>
            <div class="contact-line"><i class="fas fa-phone"></i><span>1900 1009</span></div>
            <div class="contact-line"><i class="fas fa-envelope"></i><span>support@yukisora.vn</span></div>
            <div class="contact-line"><i class="fas fa-clock"></i><span>8:00 - 18:00, Thứ 2 - Thứ 7</span></div>
            <div class="contact-line"><i class="fas fa-location-dot"></i><span>TP. Hồ Chí Minh, Việt Nam</span></div>
        </div>
    </div>
</div>
