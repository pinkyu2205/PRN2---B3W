@page
@model YukiSoraShop.Pages.Admin.AdminDashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="admin-page-header">
    <div class="admin-page-header-left">
        <h1>Dashboard</h1>
        <p>Tổng quan hệ thống, doanh thu và hoạt động gần đây</p>
    </div>
</div>

<!-- METRICS GRID -->
<div class="admin-dashboard-grid">
    <div class="metric-tile">
        <div class="metric-tile-label"><i class="fas fa-users me-2"></i>Người dùng</div>
        <div class="metric-tile-value">@Model.TotalUsers</div>
        <div class="metric-tile-change">Tổng cộng</div>
    </div>

    <div class="metric-tile">
        <div class="metric-tile-label"><i class="fas fa-box me-2"></i>Sản phẩm</div>
        <div class="metric-tile-value">@Model.TotalProducts</div>
        <div class="metric-tile-change">Công khai</div>
    </div>

    <div class="metric-tile">
        <div class="metric-tile-label"><i class="fas fa-shopping-bag me-2"></i>Đơn hàng</div>
        <div class="metric-tile-value">@Model.TotalOrders</div>
        <div class="metric-tile-change">Tất cả</div>
    </div>

    <div class="metric-tile" style="border-color: var(--color-warning);">
        <div class="metric-tile-label"><i class="fas fa-clock me-2"></i>Chờ thanh toán</div>
        <div class="metric-tile-value" style="color: var(--color-warning);">@Model.AwaitingCashOrders</div>
        <div class="metric-tile-change">Tiền mặt</div>
    </div>
</div>

<!-- REVENUE & PENDING ACTIONS -->
<div class="row g-4 mb-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted mb-2">Tổng Doanh Thu</h6>
                <h2 class="fw-bold" style="color: var(--color-success);">@Model.TotalRevenue.ToString("N0")</h2>
                <small class="text-muted">VNĐ (Tháng này)</small>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">
                    <i class="fas fa-exclamation-circle text-warning me-2"></i>
                    Yêu cầu cần chú ý
                </h5>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <a href="~/Admin/ShopApplications" class="list-group-item list-group-item-action">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">Duyệt đơn shop</h6>
                                <small class="text-muted">Có đơn chờ duyệt</small>
                            </div>
                            <span class="badge bg-warning">Cần duyệt</span>
                        </div>
                    </a>
                    <a href="~/Admin/CashPayments" class="list-group-item list-group-item-action">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">Xác nhận thanh toán tiền mặt</h6>
                                <small class="text-muted">@Model.AwaitingCashOrders đơn hàng</small>
                            </div>
                            <span class="badge bg-info">@Model.AwaitingCashOrders</span>
                        </div>
                    </a>
                    <a href="~/Admin/PaymentMethods" class="list-group-item list-group-item-action">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">Cài đặt phương thức thanh toán</h6>
                                <small class="text-muted">Kiểm tra tình trạng VNPay</small>
                            </div>
                            <i class="fas fa-arrow-right text-primary"></i>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CHART & TABLES -->
<div class="row g-4">
    <div class="col-lg-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Doanh thu & Đơn hàng gần đây</h5>
            </div>
            <div class="card-body">
                <canvas id="overviewChart" style="height: 250px;"></canvas>
            </div>
        </div>
    </div>
</div>

    <!-- SYSTEM INFO SECTION -->
    <div class="row mt-4">
        <div class="col-lg-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">
                    <i class="fas fa-info-circle text-primary me-2"></i> Thông tin hệ thống
                </div>
                <div class="card-body">
                    <p class="text-muted">
                        Xin chào, <strong>Admin!</strong> Đây là trung tâm điều khiển của YukiSora Shop.
                        Bạn có thể theo dõi thống kê người dùng, sản phẩm, đơn hàng và doanh thu theo thời gian thực.
                    </p>
                    <ul class="list-unstyled mb-0">
                        <li><i class="fas fa-check-circle text-success me-2"></i> Cập nhật số liệu trực tiếp qua SignalR</li>
                        <li><i class="fas fa-check-circle text-success me-2"></i> Bảo mật phân quyền quản trị viên</li>
                        <li><i class="fas fa-check-circle text-success me-2"></i> Thiết kế responsive, thân thiện trên mọi thiết bị</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const ctx = document.getElementById('overviewChart');
            if (!ctx) {
                console.error("Không tìm thấy phần tử canvas #overviewChart");
                return;
            }

            const overviewChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['T1', 'T2', 'T3', 'T4', 'T5', 'T6'],
                    datasets: [
                        {
                            label: 'Doanh thu (VNĐ)',
                            data: [12000000, 18000000, 14000000, 21000000, 26000000, 32000000],
                            borderColor: '#198754',
                            backgroundColor: 'rgba(25,135,84,0.1)',
                            fill: true,
                            tension: 0.4
                        },
                        {
                            label: 'Đơn hàng',
                            data: [80, 95, 70, 110, 130, 160],
                            borderColor: '#0d6efd',
                            backgroundColor: 'rgba(13,110,253,0.1)',
                            fill: true,
                            tension: 0.4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { usePointStyle: true }
                        }
                    },
                    scales: { y: { beginAtZero: true } }
                }
            });
        });

        // SignalR cập nhật dashboard
        (() => {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/adminDashboard")
                .withAutomaticReconnect()
                .build();

            connection.on("DashboardSummaryUpdated", summary => {
                if (!summary) return;
                // Update UI with new summary data
                console.log("Dashboard updated", summary);
            });

            connection.start().catch(err => console.error("SignalR error:", err));
        })();
    </script>
}
