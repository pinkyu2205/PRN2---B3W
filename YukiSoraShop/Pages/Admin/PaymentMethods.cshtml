@page
@model YukiSoraShop.Pages.Admin.PaymentMethodsModel
@{
    ViewData["Title"] = "Quản lý phương thức thanh toán";
}

<div class="admin-page-header">
    <div class="admin-page-header-left">
        <h1>Quản lý phương thức thanh toán</h1>
        <p>Kích hoạt hoặc tắt các phương thức thanh toán trong hệ thống</p>
    </div>
</div>

@await Html.PartialAsync("_Alerts")

@if (Model.Methods.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">
            <i class="fas fa-credit-card"></i>
        </div>
        <div class="empty-state-title">Chưa có phương thức thanh toán</div>
        <div class="empty-state-message">Hiện tại chưa có phương thức thanh toán nào trong hệ thống.</div>
    </div>
}
else
{
    <!-- METRICS -->
    <div class="admin-dashboard-grid">
        <div class="metric-tile">
            <div class="metric-tile-label"><i class="fas fa-list-ul me-2"></i>Tổng phương thức</div>
            <div class="metric-tile-value">@Model.Methods.Count</div>
            <div class="metric-tile-change">Tất cả</div>
        </div>

        <div class="metric-tile" style="border-color: var(--color-success);">
            <div class="metric-tile-label"><i class="fas fa-check-circle me-2"></i>Đang kích hoạt</div>
            <div class="metric-tile-value" style="color: var(--color-success);">@Model.Methods.Count(m => m.IsActive)</div>
            <div class="metric-tile-change">Có sẵn</div>
        </div>

        <div class="metric-tile" style="border-color: #6c757d;">
            <div class="metric-tile-label"><i class="fas fa-ban me-2"></i>Đang tắt</div>
            <div class="metric-tile-value" style="color: #6c757d;">@Model.Methods.Count(m => !m.IsActive)</div>
            <div class="metric-tile-change">Không hoạt động</div>
        </div>
    </div>

    <!-- DATA TABLE -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 70px;">ID</th>
                            <th style="width: 140px;">Tên phương thức</th>
                            <th style="width: 220px;">Mô tả</th>
                            <th style="width: 120px;">Trạng thái</th>
                            <th style="width: 140px;">Cập nhật lần cuối</th>
                            <th style="width: 100px;" class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var method in Model.Methods)
                        {
                            <tr>
                                <td><strong>#@method.Id</strong></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        @if (method.Name == "VNPay")
                                        {
                                            <i class="fas fa-credit-card text-primary fa-lg"></i>
                                        }
                                        else if (method.Name == "Cash")
                                        {
                                            <i class="fas fa-money-bill-wave text-success fa-lg"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-wallet text-info fa-lg"></i>
                                        }
                                        <span class="fw-semibold">@method.Name</span>
                                    </div>
                                </td>
                                <td>
                                    <small class="text-muted">
                                        @(string.IsNullOrWhiteSpace(method.Description) ? "—" : method.Description)
                                    </small>
                                </td>
                                <td>
                                    @if (method.IsActive)
                                    {
                                        <span class="status-badge success">
                                            <i class="fas fa-check-circle me-1"></i>Kích hoạt
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge">
                                            <i class="fas fa-times-circle me-1"></i>Tắt
                                        </span>
                                    }
                                </td>
                                <td>
                                    <small class="text-muted">
                                        @if (method.ModifiedAt.HasValue)
                                        {
                                            <i class="fas fa-clock me-1"></i>
                                            <span>@method.ModifiedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                            @if (!string.IsNullOrWhiteSpace(method.ModifiedBy))
                                            {
                                                <br><i class="fas fa-user me-1"></i>@method.ModifiedBy
                                            }
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </small>
                                </td>
                                <td class="text-center">
                                    <form method="post" asp-page-handler="SetStatus" class="d-inline" 
                                          onsubmit="return confirm('@(method.IsActive ? "Tắt phương thức này?" : "Kích hoạt phương thức này?")');">
                                        <input type="hidden" name="id" value="@method.Id" />
                                        @if (method.IsActive)
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-danger" name="isActive" value="false" title="Tắt phương thức">
                                                <i class="fas fa-ban"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-success" name="isActive" value="true" title="Kích hoạt phương thức">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        }
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- HELP SECTION -->
    <div class="alert alert-info mt-4">
        <h6 class="alert-heading"><i class="fas fa-info-circle me-2"></i>Hướng dẫn</h6>
        <ul class="mb-0 small">
            <li><strong>Đang kích hoạt:</strong> Khách hàng có thể chọn phương thức này để thanh toán</li>
            <li><strong>Đang tắt:</strong> Khách hàng không thể chọn phương thức này</li>
            <li>Click nút để thay đổi trạng thái</li>
        </ul>
    </div>
}

@section Scripts {
    <script>
        setTimeout(() => {
            const alerts = document.querySelectorAll('.alert-success, .alert-danger');
            alerts.forEach(alert => {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
}
