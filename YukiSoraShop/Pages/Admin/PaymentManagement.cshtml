@page
@model YukiSoraShop.Pages.Admin.PaymentManagementModel
@{
    ViewData["Title"] = "Quản lý thanh toán";
}

<div class="admin-page-header">
    <div class="admin-page-header-left">
        <h1>Quản lý thanh toán</h1>
        <p>Theo dõi và quản lý toàn bộ giao dịch thanh toán của hệ thống.</p>
    </div>
</div>

@await Html.PartialAsync("_Alerts")

<div class="admin-dashboard-grid">
    <div class="metric-tile">
        <div class="metric-tile-label"><i class="fas fa-receipt me-2"></i>Tổng giao dịch</div>
        <div class="metric-tile-value">@Model.TotalPayments</div>
        <div class="metric-tile-change">Trang hiện tại</div>
    </div>
    <div class="metric-tile" style="border-color: var(--color-success);">
        <div class="metric-tile-label"><i class="fas fa-check-circle me-2"></i>Thành công</div>
        <div class="metric-tile-value" style="color: var(--color-success);">@Model.PaidCount</div>
        <div class="metric-tile-change">Đã thanh toán</div>
    </div>
    <div class="metric-tile" style="border-color: var(--color-warning);">
        <div class="metric-tile-label"><i class="fas fa-clock me-2"></i>Chờ xử lý</div>
        <div class="metric-tile-value" style="color: var(--color-warning);">@Model.PendingCount</div>
        <div class="metric-tile-change">Đang chờ</div>
    </div>
    <div class="metric-tile" style="border-color: var(--color-success);">
        <div class="metric-tile-label"><i class="fas fa-sack-dollar me-2"></i>Doanh thu</div>
        <div class="metric-tile-value" style="color: var(--color-success);">@Model.TotalRevenue.ToString("N0")</div>
        <div class="metric-tile-change">VNĐ</div>
    </div>
</div>

<form method="get" class="toolbar mb-4">
    <div class="toolbar-filters">
        <input type="text" class="form-control form-control-sm" name="search" value="@Model.Search" placeholder="Tìm theo mã đơn, mã thanh toán, mã giao dịch..." style="max-width: 320px;">
        <input type="number" class="form-control form-control-sm" name="orderId" value="@Model.OrderId" placeholder="Lọc theo mã đơn" min="1" style="max-width: 160px;">
        <select class="form-select form-select-sm" name="method" style="max-width: 170px;">
            <option value="">-- Phương thức --</option>
            <option value="VNPay" selected="@(Model.Method == "VNPay")">VNPay</option>
            <option value="Cash" selected="@(Model.Method == "Cash")">Tiền mặt</option>
        </select>
        <select class="form-select form-select-sm" name="status" style="max-width: 170px;">
            <option value="">-- Trạng thái --</option>
            <option value="Paid" selected="@(Model.Status == Domain.Enums.PaymentStatus.Paid)">Đã thanh toán</option>
            <option value="Pending" selected="@(Model.Status == Domain.Enums.PaymentStatus.Pending)">Đang chờ</option>
            <option value="Canceled" selected="@(Model.Status == Domain.Enums.PaymentStatus.Canceled)">Đã hủy</option>
            <option value="Refunded" selected="@(Model.Status == Domain.Enums.PaymentStatus.Refunded)">Hoàn tiền</option>
        </select>
        <input type="hidden" name="pageNumber" value="1" />
        <input type="hidden" name="pageSize" value="@Model.PageSize" />
    </div>
    <div class="toolbar-actions">
        <a class="btn btn-sm btn-outline-secondary" asp-page="/Admin/PaymentManagement"><i class="fas fa-rotate-left me-1"></i>Đặt lại</a>
        <button class="btn btn-sm btn-primary" type="submit"><i class="fas fa-filter me-1"></i>Lọc</button>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Payments.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon"><i class="fas fa-inbox"></i></div>
                <div class="empty-state-title">Chưa có giao dịch</div>
                <div class="empty-state-message">Không tìm thấy giao dịch phù hợp với bộ lọc hiện tại.</div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th style="width: 160px;">Mã giao dịch</th>
                            <th style="width: 110px;">Mã đơn</th>
                            <th style="width: 120px;">Phương thức</th>
                            <th style="width: 140px;" class="text-end">Số tiền</th>
                            <th style="width: 120px;">Trạng thái</th>
                            <th style="width: 150px;">Ngày tạo</th>
                            <th style="width: 90px;" class="text-center">Chi tiết</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model.Payments)
                        {
                            <tr>
                                <td><strong>#@payment.PaymentId</strong></td>
                                <td><small class="font-monospace text-muted">@(payment.TransactionRef ?? $"PMT-{payment.PaymentId:D6}")</small></td>
                                <td>
                                    <a asp-page="/Admin/PaymentManagement" asp-route-orderId="@payment.OrderId" class="text-decoration-none fw-semibold">
                                        #@payment.OrderId
                                    </a>
                                </td>
                                <td>
                                    @if (payment.PaymentMethod == "VNPay")
                                    {
                                        <span class="status-badge info"><i class="fas fa-credit-card me-1"></i>VNPay</span>
                                    }
                                    else if (payment.PaymentMethod == "Cash")
                                    {
                                        <span class="status-badge success"><i class="fas fa-money-bill-wave me-1"></i>Tiền mặt</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge">@payment.PaymentMethod</span>
                                    }
                                </td>
                                <td class="text-end"><strong>@payment.Amount.ToString("N0") VNĐ</strong></td>
                                <td>
                                    @switch (payment.Status)
                                    {
                                        case Domain.Enums.PaymentStatus.Paid:
                                            <span class="status-badge success"><i class="fas fa-check-circle me-1"></i>Đã thanh toán</span>
                                            break;
                                        case Domain.Enums.PaymentStatus.Pending:
                                            <span class="status-badge warning"><i class="fas fa-clock me-1"></i>Chờ xử lý</span>
                                            break;
                                        case Domain.Enums.PaymentStatus.Canceled:
                                            <span class="status-badge danger"><i class="fas fa-times-circle me-1"></i>Đã hủy</span>
                                            break;
                                        case Domain.Enums.PaymentStatus.Refunded:
                                            <span class="status-badge info"><i class="fas fa-rotate-left me-1"></i>Hoàn tiền</span>
                                            break;
                                        default:
                                            <span class="status-badge">@payment.StatusDisplay</span>
                                            break;
                                    }
                                </td>
                                <td><small class="text-muted">@payment.CreatedAtDisplay</small></td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#paymentDetailModal" onclick="loadPaymentDetail(@payment.PaymentId)" title="Xem chi tiết">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (Model.Payments.Count > 0)
{
    <nav aria-label="Payment pagination" class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                <a class="page-link" asp-page="/Admin/PaymentManagement" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-orderId="@Model.OrderId" asp-route-method="@Model.Method" asp-route-status="@Model.Status">Trước</a>
            </li>
            <li class="page-item active"><span class="page-link">Trang @Model.PageNumber</span></li>
            <li class="page-item">
                <a class="page-link" asp-page="/Admin/PaymentManagement" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-orderId="@Model.OrderId" asp-route-method="@Model.Method" asp-route-status="@Model.Status">Tiếp</a>
            </li>
        </ul>
    </nav>
}

<div class="modal fade" id="paymentDetailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-file-invoice me-2"></i>Chi tiết giao dịch</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="paymentDetailContent">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="text-muted mt-3">Đang tải dữ liệu...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="fas fa-times me-1"></i>Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadPaymentDetail(paymentId) {
            const content = document.getElementById('paymentDetailContent');

            content.innerHTML = `
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="text-muted mt-3">Đang tải dữ liệu...</p>
                </div>`;

            fetch(`?handler=Detail&id=${paymentId}`)
                .then(response => {
                    if (!response.ok) throw new Error('Network response was not ok');
                    return response.json();
                })
                .then(payment => {
                    const statusClass = {
                        'Đã thanh toán': 'success',
                        'Chờ xử lý': 'warning',
                        'Đã hủy': 'danger',
                        'Hoàn tiền': 'info'
                    }[payment.statusDisplay] || 'secondary';

                    content.innerHTML = `
                        <div class="row g-3">
                            <div class="col-md-6">
                                <h6 class="fw-semibold mb-3">Thông tin giao dịch</h6>
                                <div class="form-group">
                                    <label class="form-group-label">ID giao dịch</label>
                                    <p class="mb-3"><strong>#${payment.paymentId}</strong></p>
                                </div>
                                <div class="form-group">
                                    <label class="form-group-label">Mã giao dịch</label>
                                    <p class="mb-3"><code>${payment.transactionRef || 'Không có'}</code></p>
                                </div>
                                <div class="form-group">
                                    <label class="form-group-label">Mã đơn hàng</label>
                                    <p class="mb-0"><strong>#${payment.orderId}</strong></p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <h6 class="fw-semibold mb-3">Chi tiết thanh toán</h6>
                                <div class="form-group">
                                    <label class="form-group-label">Phương thức</label>
                                    <p class="mb-3"><strong>${payment.paymentMethod}</strong></p>
                                </div>
                                <div class="form-group">
                                    <label class="form-group-label">Số tiền</label>
                                    <p class="mb-3"><strong class="text-success">${payment.amount.toLocaleString('vi-VN')} VNĐ</strong></p>
                                </div>
                                <div class="form-group">
                                    <label class="form-group-label">Trạng thái</label>
                                    <p class="mb-0"><span class="status-badge ${statusClass}">${payment.statusDisplay}</span></p>
                                </div>
                            </div>
                            <div class="col-12">
                                <hr>
                                <p class="text-muted mb-0"><i class="fas fa-calendar me-2"></i>Ngày tạo: ${payment.createdAtDisplay}</p>
                            </div>
                        </div>`;
                })
                .catch(() => {
                    content.innerHTML = `
                        <div class="alert alert-danger mb-0">
                            <i class="fas fa-exclamation-circle me-2"></i>Lỗi khi tải dữ liệu. Vui lòng thử lại.
                        </div>`;
                });
        }
    </script>
}
