@page
@model YukiSoraShop.Pages.Admin.ShopApplicationsModel
@{
    ViewData["Title"] = "Duyệt đơn đăng ký cửa hàng";
}

<div class="admin-page-header">
    <div class="admin-page-header-left">
        <h1>Duyệt đơn đăng ký cửa hàng</h1>
        <p>Quản lý các đơn đăng ký mở cửa hàng từ người dùng</p>
    </div>
</div>

<!-- METRICS -->
<div class="admin-dashboard-grid">
    <div class="metric-tile" style="border-color: var(--color-warning);">
        <div class="metric-tile-label"><i class="fas fa-clock me-2"></i>Đang chờ</div>
        <div class="metric-tile-value" style="color: var(--color-warning);">@Model.Applications.Count(a => a.Status == Domain.Enums.ShopApplicationStatus.Pending)</div>
        <div class="metric-tile-change">Cần xử lý</div>
    </div>

    <div class="metric-tile" style="border-color: var(--color-success);">
        <div class="metric-tile-label"><i class="fas fa-check-circle me-2"></i>Đã duyệt</div>
        <div class="metric-tile-value" style="color: var(--color-success);">@Model.Applications.Count(a => a.Status == Domain.Enums.ShopApplicationStatus.Approved)</div>
        <div class="metric-tile-change">Đã chấp nhận</div>
    </div>

    <div class="metric-tile" style="border-color: var(--color-danger);">
        <div class="metric-tile-label"><i class="fas fa-times-circle me-2"></i>Từ chối</div>
        <div class="metric-tile-value" style="color: var(--color-danger);">@Model.Applications.Count(a => a.Status == Domain.Enums.ShopApplicationStatus.Rejected)</div>
        <div class="metric-tile-change">Bị từ chối</div>
    </div>

    <div class="metric-tile">
        <div class="metric-tile-label"><i class="fas fa-store me-2"></i>Tổng cộng</div>
        <div class="metric-tile-value">@Model.Applications.Count</div>
        <div class="metric-tile-change">Tất cả đơn</div>
    </div>
</div>

<!-- TOOLBAR -->
<div class="toolbar mb-4">
    <div class="toolbar-filters">
        <form method="get" class="d-flex gap-2 align-items-end" style="width: 100%;">
            <select name="StatusFilter" class="form-select form-select-sm" style="max-width: 150px;">
                <option value="">-- Trạng thái --</option>
                <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Đang chờ</option>
                <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Đã duyệt</option>
                <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Từ chối</option>
            </select>
            <button type="submit" class="btn btn-sm btn-outline-primary">
                <i class="fas fa-filter me-1"></i>Lọc
            </button>
            @if (!string.IsNullOrWhiteSpace(Model.StatusFilter))
            {
                <a asp-page="/Admin/ShopApplications" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-times me-1"></i>Xóa lọc
                </a>
            }
        </form>
    </div>
</div>

<!-- DATA TABLE -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Applications.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fas fa-clipboard"></i>
                </div>
                <div class="empty-state-title">Chưa có đơn đăng ký</div>
                <div class="empty-state-message">Hiện tại chưa có đơn đăng ký mở cửa hàng nào.</div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 60px;">ID</th>
                            <th style="width: 160px;">Người đăng ký</th>
                            <th style="width: 140px;">Tên cửa hàng</th>
                            <th style="width: 150px;">Mô tả</th>
                            <th style="width: 100px;">SĐT</th>
                            <th style="width: 120px;">Ngày gửi</th>
                            <th style="width: 100px;">Trạng thái</th>
                            <th style="width: 100px;" class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model.Applications.OrderByDescending(a => a.CreatedAt))
                        {
                            <tr>
                                <td><strong>#@app.Id</strong></td>
                                <td>
                                    @if (app.Applicant != null)
                                    {
                                        <div>
                                            <strong>@(app.Applicant.FullName ?? app.Applicant.UserName)</strong><br>
                                            <small class="text-muted">@app.Applicant.Email</small>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td><strong>@app.ShopName</strong></td>
                                <td>
                                    <small class="text-muted" title="@app.Description">
                                        @(app.Description?.Length > 40 ? app.Description[..40] + "..." : app.Description ?? "—")
                                    </small>
                                </td>
                                <td>@(app.PhoneNumber ?? "—")</td>
                                <td><small class="text-muted">@app.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small></td>
                                <td>
                                    @switch (app.Status)
                                    {
                                        case Domain.Enums.ShopApplicationStatus.Pending:
                                            <span class="status-badge warning">
                                                <i class="fas fa-clock me-1"></i>Đang chờ
                                            </span>
                                            break;
                                        case Domain.Enums.ShopApplicationStatus.Approved:
                                            <span class="status-badge success">
                                                <i class="fas fa-check-circle me-1"></i>Đã duyệt
                                            </span>
                                            break;
                                        case Domain.Enums.ShopApplicationStatus.Rejected:
                                            <span class="status-badge danger">
                                                <i class="fas fa-times-circle me-1"></i>Từ chối
                                            </span>
                                            break;
                                    }
                                </td>
                                <td class="text-center">
                                    @if (app.Status == Domain.Enums.ShopApplicationStatus.Pending)
                                    {
                                        <form method="post" asp-page-handler="Approve" asp-route-id="@app.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Duyệt"
                                                    onclick="return confirm('Xác nhận duyệt cửa hàng này?')">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        </form>
                                        <button type="button" class="btn btn-sm btn-outline-danger" title="Từ chối"
                                                data-bs-toggle="modal" data-bs-target="#rejectModal-@app.Id">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Đã xử lý</span>
                                    }
                                </td>
                            </tr>

                            @if (app.Status == Domain.Enums.ShopApplicationStatus.Pending)
                            {
                                <!-- Reject Modal -->
                                <div class="modal fade" id="rejectModal-@app.Id" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <form method="post" asp-page-handler="Reject" asp-route-id="@app.Id">
                                                <div class="modal-header bg-danger text-white">
                                                    <h5 class="modal-title">
                                                        <i class="fas fa-times-circle me-2"></i>Từ chối đơn: @app.ShopName
                                                    </h5>
                                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <div class="form-group">
                                                        <label class="form-group-label">Lý do từ chối</label>
                                                        <textarea name="RejectReason" class="form-control" rows="4" placeholder="Nhập lý do từ chối..." required></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                                    <button type="submit" class="btn btn-danger">Từ chối</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
