@page
@model YukiSoraShop.Pages.Admin.ShopApplicationsModel
@{
    ViewData["Title"] = "Duyệt đơn đăng ký Shop";
}

<div class="container-fluid py-4">
    <h2 class="mb-4"><i class="fas fa-clipboard-check me-2"></i>Duyệt đơn đăng ký Shop</h2>

    <!-- Filter -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="d-flex gap-2 align-items-end">
                <div>
                    <label class="form-label fw-bold">Lọc theo trạng thái</label>
                    <select name="StatusFilter" class="form-select" style="width: 200px;">
                        <option value="">Tất cả</option>
                        <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Đang chờ</option>
                        <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Đã duyệt</option>
                        <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Từ chối</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-filter me-1"></i> Lọc
                </button>
                @if (!string.IsNullOrWhiteSpace(Model.StatusFilter))
                {
                    <a asp-page="/Admin/ShopApplications" class="btn btn-outline-secondary">
                        <i class="fas fa-times me-1"></i> Xóa bộ lọc
                    </a>
                }
            </form>
        </div>
    </div>

    <!-- Summary -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h3 class="text-warning">@Model.Applications.Count(a => a.Status == Domain.Enums.ShopApplicationStatus.Pending)</h3>
                    <small class="text-muted">Đang chờ duyệt</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h3 class="text-success">@Model.Applications.Count(a => a.Status == Domain.Enums.ShopApplicationStatus.Approved)</h3>
                    <small class="text-muted">Đã duyệt</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h3 class="text-danger">@Model.Applications.Count(a => a.Status == Domain.Enums.ShopApplicationStatus.Rejected)</h3>
                    <small class="text-muted">Từ chối</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Applications Table -->
    @if (Model.Applications.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Người đăng ký</th>
                                <th>Tên Shop</th>
                                <th>Mô tả</th>
                                <th>SĐT</th>
                                <th>Ngày gửi</th>
                                <th>Trạng thái</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var app in Model.Applications.OrderByDescending(a => a.CreatedAt))
                            {
                                <tr>
                                    <td>@app.Id</td>
                                    <td>
                                        @if (app.Applicant != null)
                                        {
                                            <div>
                                                <strong>@(app.Applicant.FullName ?? app.Applicant.UserName)</strong>
                                                <br /><small class="text-muted">@app.Applicant.Email</small>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>
                                    <td><strong>@app.ShopName</strong></td>
                                    <td>
                                        <span title="@app.Description">
                                            @(app.Description?.Length > 50 ? app.Description[..50] + "..." : app.Description ?? "—")
                                        </span>
                                    </td>
                                    <td>@(app.PhoneNumber ?? "—")</td>
                                    <td>@app.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @switch (app.Status)
                                        {
                                            case Domain.Enums.ShopApplicationStatus.Pending:
                                                <span class="badge bg-warning text-dark">Đang chờ</span>
                                                break;
                                            case Domain.Enums.ShopApplicationStatus.Approved:
                                                <span class="badge bg-success">Đã duyệt</span>
                                                if (app.ReviewedAt.HasValue)
                                                {
                                                    <br /><small class="text-muted">@app.ReviewedAt.Value.ToString("dd/MM/yyyy")</small>
                                                }
                                                break;
                                            case Domain.Enums.ShopApplicationStatus.Rejected:
                                                <span class="badge bg-danger">Từ chối</span>
                                                if (!string.IsNullOrWhiteSpace(app.AdminNote))
                                                {
                                                    <br /><small class="text-danger" title="@app.AdminNote">@(app.AdminNote.Length > 30 ? app.AdminNote[..30] + "..." : app.AdminNote)</small>
                                                }
                                                break;
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (app.Status == Domain.Enums.ShopApplicationStatus.Pending)
                                        {
                                            <div class="d-flex gap-1 justify-content-center">
                                                <form method="post" asp-page-handler="Approve" asp-route-id="@app.Id" class="d-inline">
                                                    <button type="submit" class="btn btn-success btn-sm" title="Duyệt"
                                                            onclick="return confirm('Bạn có chắc chắn muốn duyệt shop này?')">
                                                        <i class="fas fa-check"></i> Duyệt
                                                    </button>
                                                </form>
                                                <button type="button" class="btn btn-danger btn-sm" title="Từ chối"
                                                        data-bs-toggle="modal" data-bs-target="#rejectModal-@app.Id">
                                                    <i class="fas fa-times"></i> Từ chối
                                                </button>
                                            </div>

                                            <!-- Reject Modal -->
                                            <div class="modal fade" id="rejectModal-@app.Id" tabindex="-1">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <form method="post" asp-page-handler="Reject" asp-route-id="@app.Id">
                                                            <div class="modal-header bg-danger text-white">
                                                                <h5 class="modal-title">Từ chối đơn: @app.ShopName</h5>
                                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                            </div>
                                                            <div class="modal-body">
                                                                <div class="mb-3">
                                                                    <label class="form-label fw-bold">Lý do từ chối</label>
                                                                    <textarea name="RejectReason" class="form-control" rows="3"
                                                                              placeholder="Nhập lý do từ chối..."></textarea>
                                                                </div>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                                                <button type="submit" class="btn btn-danger">Từ chối</button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Đã xử lý</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="fas fa-inbox fa-3x mb-3"></i>
            <p>Không có đơn đăng ký nào.</p>
        </div>
    }
</div>
