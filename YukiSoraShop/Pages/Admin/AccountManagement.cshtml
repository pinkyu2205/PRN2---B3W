@page
@model YukiSoraShop.Pages.Admin.AccountManagementModel
@{
    ViewData["Title"] = "Quản lý tài khoản";
}

<div class="admin-page-header">
    <div class="admin-page-header-left">
        <h1>Quản lý tài khoản</h1>
        <p>Quản lý tất cả các tài khoản người dùng trong hệ thống</p>
    </div>
</div>

<!-- TOOLBAR -->
<div class="toolbar mb-4">
    <div class="toolbar-filters">
        <input type="text" class="form-control form-control-sm" placeholder="Tìm kiếm theo email, tên..." style="max-width: 300px;">
        <select class="form-select form-select-sm" style="max-width: 150px;">
            <option selected>-- Vai trò --</option>
            <option>Khách hàng</option>
            <option>Nhân viên</option>
            <option>Quản lý cửa hàng</option>
        </select>
    </div>
    <div class="toolbar-actions">
        <button class="btn btn-sm btn-outline-primary">
            <i class="fas fa-download me-1"></i>Xuất
        </button>
    </div>
</div>

<!-- DATA TABLE -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Users.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fas fa-users"></i>
                </div>
                <div class="empty-state-title">Chưa có tài khoản</div>
                <div class="empty-state-message">Hiện tại chưa có tài khoản nào để hiển thị.</div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th style="width: 180px;">Email / Username</th>
                            <th style="width: 150px;">Họ Tên</th>
                            <th style="width: 130px;">Số điện thoại</th>
                            <th style="width: 200px;">Địa chỉ</th>
                            <th style="width: 100px;">Ngày tạo</th>
                            <th style="width: 100px;" class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td><strong>#@user.Id</strong></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar" style="width: 32px; height: 32px; background: linear-gradient(135deg, var(--color-primary), #0dcaf0); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600;">
                                            @user.Email.FirstOrDefault()
                                        </div>
                                        <div>
                                            <strong>@user.Email</strong><br>
                                            <small class="text-muted">@user.Username</small>
                                        </div>
                                    </div>
                                </td>
                                <td>@user.FullName</td>
                                <td>
                                    <small>@user.PhoneNumber</small>
                                </td>
                                <td>
                                    <small class="text-muted">@user.Address</small>
                                </td>
                                <td>
                                    <small class="text-muted">@user.CreatedAt.ToShortDateString()</small>
                                </td>
                                <td class="text-center">
                                    <a href="/Admin/AccountManagement?id=@user.Id" class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="/Customer/EditProfile?id=@user.Id" class="btn btn-sm btn-outline-warning" title="Chỉnh sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button class="btn btn-sm btn-outline-danger" onclick="confirmDelete('@user.Id', '@user.FullName')" title="Xóa mềm">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            if (confirm(`Bạn có chắc chắn muốn xóa mềm tài khoản của ${name} (ID: ${id}) không?`)) {
                alert("Chức năng xóa sẽ được triển khai sau!");
            }
        }
    </script>
}
