<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - YukiSora Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="admin-shell">
    <div class="admin-container">
        <!-- SIDEBAR -->
        <aside class="admin-sidebar">
            <div class="admin-sidebar-brand">
                <span class="brand-mark"><i class="fas fa-crown"></i></span>
                <div>
                    <strong>YukiSora Admin</strong>
                    <small>Bảng điều hành</small>
                </div>
            </div>

            <nav class="admin-sidebar-nav">
                <!-- Main Navigation -->
                <div class="admin-sidebar-nav-section">
                    <div class="admin-sidebar-nav-section-title">Menu chính</div>
                    <a href="~/Admin/Dashboard" class="admin-sidebar-nav-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("Dashboard") == true ? "active" : "")">
                        <i class="fas fa-chart-line"></i>
                        <span>Dashboard</span>
                    </a>
                </div>

                <!-- Shop Management -->
                <div class="admin-sidebar-nav-section">
                    <div class="admin-sidebar-nav-section-title">Quản lý shop</div>
                    <a href="~/Admin/ShopApplications" class="admin-sidebar-nav-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("ShopApplications") == true ? "active" : "")">
                        <i class="fas fa-store"></i>
                        <span>Duyệt shop</span>
                    </a>
                </div>

                <!-- Payment Management -->
                <div class="admin-sidebar-nav-section">
                    <div class="admin-sidebar-nav-section-title">Thanh toán</div>
                    <a href="~/Admin/PaymentMethods" class="admin-sidebar-nav-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("PaymentMethods") == true ? "active" : "")">
                        <i class="fas fa-credit-card"></i>
                        <span>Phương thức thanh toán</span>
                    </a>
                    <a href="~/Admin/PaymentManagement" class="admin-sidebar-nav-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("PaymentManagement") == true ? "active" : "")">
                        <i class="fas fa-wallet"></i>
                        <span>Quản lý thanh toán</span>
                    </a>
                    <a href="~/Admin/CashPayments" class="admin-sidebar-nav-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("CashPayments") == true ? "active" : "")">
                        <i class="fas fa-hand-holding-usd"></i>
                        <span>Thanh toán tiền mặt</span>
                    </a>
                </div>

                <!-- Account Management -->
                <div class="admin-sidebar-nav-section">
                    <div class="admin-sidebar-nav-section-title">Hệ thống</div>
                    <a href="~/Admin/AccountManagement" class="admin-sidebar-nav-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("AccountManagement") == true ? "active" : "")">
                        <i class="fas fa-users"></i>
                        <span>Quản lý tài khoản</span>
                    </a>
                </div>
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="admin-main">
            <!-- TOPBAR -->
            <header class="admin-topbar">
                <div class="admin-topbar-heading">
                    <span class="admin-topbar-label">Bảng điều khiển</span>
                    <div class="admin-topbar-title" id="pageTitle">
                        @ViewData["Title"]
                    </div>
                </div>
                <div class="admin-topbar-actions">
                    <a href="~/Customer/Catalog" class="admin-topbar-action" title="Về trang mua sắm">
                        <i class="fas fa-arrow-up-right-from-square"></i>
                    </a>
                    <a href="#" class="admin-topbar-action" title="Thông báo">
                        <i class="fas fa-bell"></i>
                    </a>
                    <a href="~/Auth/Logout" class="admin-topbar-action" title="Đăng xuất">
                        <i class="fas fa-sign-out-alt"></i>
                    </a>
                </div>
            </header>

            <!-- PAGE CONTENT -->
            <main class="admin-content">
                @await Html.PartialAsync("_Alerts")
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <!-- SignalR & Realtime integration -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="~/js/realtime-notification.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
