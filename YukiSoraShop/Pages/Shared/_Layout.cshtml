<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - YukiSora Technology</title>

    <!-- Bootstrap, FontAwesome, Google Fonts -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #F9FAFB;
        }

        /* HEADER */
        .navbar {
            background: #FFFFFF;
            border-bottom: 1px solid #E5E7EB;
        }

        .navbar-brand {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700;
            font-size: 1.25rem;
            letter-spacing: 0.02em;
            color: #111827 !important;
        }

            .navbar-brand i {
                color: #111827;
            }

        .nav-link {
            color: #4B5563 !important;
            font-weight: 600;
            transition: 0.3s ease;
        }

            .nav-link:hover {
                color: #111827 !important;
                text-decoration: none;
            }

        /* MAIN CONTENT */
        main.container {
            padding-top: 40px;
            padding-bottom: 40px;
        }

        /* FOOTER */
        footer {
            background: #111827;
            color: #D1D5DB;
            font-size: 0.9rem;
        }

            footer h6 {
                color: #FFFFFF;
                font-weight: 600;
            }

            footer a {
                color: #9CA3AF;
                text-decoration: none;
            }

                footer a:hover {
                    color: #FFFFFF;
                    text-decoration: underline;
                }

        .footer-bottom {
            border-top: 1px solid #374151;
            margin-top: 1.5rem;
            padding-top: 1rem;
            text-align: center;
            color: #9CA3AF;
        }
    </style>
</head>

<body>
    <!-- ===== HEADER ===== -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/Customer/Catalog">
                <i class="fas fa-bolt me-2"></i>YukiSora<span class="text-dark">Tech</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                @await Html.PartialAsync("_Navigation")
            </div>
        </div>
    </nav>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="container mt-4">
        @RenderBody()
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="pt-5 pb-3 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h6>YukiSora Technology</h6>
                    <p class="small">
                        Đối tác công nghệ đáng tin cậy của doanh nghiệp Việt — cung cấp giải pháp phần cứng và phần mềm hiện đại, bảo mật, tối ưu.
                    </p>
                </div>
                <div class="col-md-4">
                    <h6>Liên kết nhanh</h6>
                    <ul class="list-unstyled small">
                        <li><a href="/Customer/Catalog">Trang mua sắm</a></li>
                        <li><a href="/Customer/Catalog">Sản phẩm</a></li>
                        <li><a href="/Customer/Catalog#catalog-intro">Giới thiệu</a></li>
                        <li><a href="/Support">Hỗ trợ</a></li>
                        <li><a href="/Customer/Catalog#catalog-contact">Liên hệ</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6>Kết nối với chúng tôi</h6>
                    <a href="#" class="me-3"><i class="fab fa-facebook fa-lg"></i></a>
                    <a href="#" class="me-3"><i class="fab fa-linkedin fa-lg"></i></a>
                    <a href="#"><i class="fab fa-twitter fa-lg"></i></a>
                    <p class="small mt-3">
                        <i class="fas fa-envelope me-2"></i>support@yukisora.vn<br />
                        <i class="fas fa-phone me-2"></i>1900 1009
                    </p>
                </div>
            </div>
            <div class="footer-bottom mt-4">
                © 2025 YukiSora Technology. All rights reserved.
            </div>
        </div>
    </footer>

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- SignalR & Realtime integration -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="~/js/realtime-notification.js"></script>
    <script src="~/js/realtime-catalog.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
