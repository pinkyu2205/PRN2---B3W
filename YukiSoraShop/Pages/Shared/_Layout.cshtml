<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - YukiSora Technology</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>

<body class="app-shell">
    <div class="site-shell">
        <header class="site-header sticky-top">
            <nav class="navbar navbar-expand-lg site-navbar">
                <div class="container site-navbar-container">
                    <a class="navbar-brand site-brand d-flex align-items-center" href="/Customer/Catalog">
                        <span class="brand-mark"><i class="fas fa-bolt"></i></span>
                        <span class="brand-wordmark">YukiSora Tech</span>
                    </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

                    <div class="collapse navbar-collapse" id="navbarNav">
                        @await Html.PartialAsync("_Navigation")
                    </div>
                </div>
            </nav>
        </header>

        <main class="site-shell-main">
            <div class="container site-page-container">
                @await Html.PartialAsync("_Alerts")
                @RenderBody()
            </div>
        </main>

        <footer class="site-footer">
            <div class="container">
                <div class="row g-4 g-lg-5 align-items-start">
                    <div class="col-lg-5">
                        <span class="site-footer-label">Thương mại công nghệ</span>
                        <h2 class="site-footer-title">Hệ thống bán hàng công nghệ với trải nghiệm rõ ràng, đáng tin cậy và nhất quán.</h2>
                        <p class="site-footer-copy">
                            YukiSora tập trung vào luồng mua sắm mạch lạc, khả năng vận hành ổn định và giao diện sạch để người dùng xử lý công việc nhanh hơn.
                        </p>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <h6 class="site-footer-heading">Điều hướng</h6>
                        <ul class="site-footer-links list-unstyled">
                            <li><a href="/Customer/Catalog">Trang mua sắm</a></li>
                            <li><a href="/Customer/Catalog#catalog-intro">Giới thiệu</a></li>
                            <li><a href="/Customer/Catalog#catalog-contact">Liên hệ</a></li>
                            <li><a href="/Support">Hỗ trợ</a></li>
                        </ul>
                    </div>
                    <div class="col-sm-6 col-lg-4">
                        <h6 class="site-footer-heading">Liên hệ</h6>
                        <div class="site-footer-contact">
                            <div><span>Email</span><a href="mailto:support@yukisora.vn">support@yukisora.vn</a></div>
                            <div><span>Hotline</span><a href="tel:19001009">1900 1009</a></div>
                            <div><span>Vận hành</span><p>Hệ thống giao diện đơn sắc cho cửa hàng, xác thực và quản trị.</p></div>
                        </div>
                    </div>
                </div>
                <div class="site-footer-bottom">
                    <span>© 2025 YukiSora Technology.</span>
                    <span>Tốc độ, minh bạch và tin cậy trong vận hành.</span>
                </div>
            </div>
        </footer>
    </div>

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- SignalR & Realtime integration -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="~/js/realtime-notification.js"></script>
    <script src="~/js/realtime-catalog.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
