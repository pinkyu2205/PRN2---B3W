@inject Application.Services.Interfaces.ICartService CartService
@inject Application.Services.Interfaces.INotificationService NotificationService
@using System.Security.Claims

@{
    var isAuthenticated = User?.Identity?.IsAuthenticated == true;
    var userName = User?.Identity?.Name ?? "";
    var isAdmin = User?.IsInRole("Administrator") == true;
    var isStaff = User?.IsInRole("Moderator") == true;

    // Get cart count for authenticated customers
    var cartCount = 0;
    if (isAuthenticated && !isAdmin && !isStaff)
    {
        var accountIdStr = User?.FindFirstValue(ClaimTypes.NameIdentifier);
        if (int.TryParse(accountIdStr, out var accountId) && accountId > 0)
        {
            try
            {
                var items = await CartService.GetItemsAsync(accountId);
                cartCount = items?.Sum(i => i.Quantity) ?? 0;
            }
            catch
            {
                cartCount = 0;
            }
        }
    }

    var unreadNotiCount = 0;
    var recentNotis = new List<Application.DTOs.NotificationDTO>();
    if (isAuthenticated)
    {
        var accountIdStr = User?.FindFirstValue(ClaimTypes.NameIdentifier);
        if (int.TryParse(accountIdStr, out var accountId) && accountId > 0)
        {
            try
            {
                unreadNotiCount = await NotificationService.GetUnreadCountAsync(accountId);
                recentNotis = await NotificationService.GetUserNotificationsAsync(accountId, 5);
            }
            catch { }
        }
    }
}

<!-- LEFT NAVIGATION -->
<ul class="navbar-nav me-auto align-items-lg-center site-nav-group">
    <li class="nav-item">
        <a class="nav-link fw-semibold site-nav-link" asp-page="/Customer/Catalog">
            <i class="fas fa-store me-1"></i> Mua sắm
        </a>
    </li>

    @if (isAuthenticated)
    {
        if (isAdmin)
        {
            <!-- ADMIN MENU -->
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle fw-semibold site-nav-link" href="#" role="button" data-bs-toggle="dropdown">
                    <i class="fas fa-cogs me-1"></i> Quản trị hệ thống
                </a>
                <ul class="dropdown-menu shadow-sm site-dropdown-menu">
                    <li><a class="dropdown-item" asp-page="/Admin/Dashboard"><i class="fas fa-tachometer-alt me-2"></i> Dashboard</a></li>
                    <li><a class="dropdown-item" asp-page="/Admin/AccountManagement"><i class="fas fa-users-cog me-2"></i> Quản lý tài khoản</a></li>
                    <li><a class="dropdown-item" asp-page="/Admin/PaymentMethods"><i class="fas fa-credit-card me-2"></i> Phương thức thanh toán</a></li>
                    <li><a class="dropdown-item" asp-page="/Admin/CashPayments"><i class="fas fa-hand-holding-usd me-2"></i> Thanh toán tiền mặt</a></li>
                    <li><hr class="dropdown-divider" /></li>
                    <li><a class="dropdown-item" asp-page="/Admin/ShopApplications"><i class="fas fa-clipboard-check me-2"></i> Duyệt đơn Shop</a></li>
                </ul>
            </li>
        }
        else if (isStaff)
        {
            <!-- STAFF MENU -->
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle fw-semibold site-nav-link" href="#" role="button" data-bs-toggle="dropdown">
                    <i class="fas fa-box me-1"></i> Quản lý sản phẩm
                </a>
                <ul class="dropdown-menu shadow-sm site-dropdown-menu">
                    <li><a class="dropdown-item" asp-page="/Staff/Products/List"><i class="fas fa-list me-2"></i> Danh sách sản phẩm</a></li>
                    <li><a class="dropdown-item" asp-page="/Staff/Products/Create"><i class="fas fa-plus me-2"></i> Thêm sản phẩm</a></li>
                    <li><a class="dropdown-item" asp-page="/Staff/Categories/List"><i class="fas fa-tags me-2"></i> Danh mục</a></li>
                </ul>
            </li>
        }
        else
        {
            <!-- CUSTOMER MENU -->
            <li class="nav-item">
                <a class="nav-link fw-semibold site-nav-link" asp-page="/Customer/Catalog">
                    <i class="fas fa-laptop me-1"></i> Sản phẩm
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-semibold site-nav-link" href="/Customer/Catalog#catalog-intro">
                    <i class="fas fa-info-circle me-1"></i> Giới thiệu
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-semibold site-nav-link" href="/Customer/Catalog#catalog-contact">
                    <i class="fas fa-headset me-1"></i> Liên hệ
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-semibold site-nav-link site-nav-link-accent" asp-page="/Customer/RegisterShop">
                    <i class="fas fa-store me-1"></i> Đăng ký Shop
                </a>
            </li>
        }
    }
    else
    {
        <!-- Guest menu -->
        <li class="nav-item">
            <a class="nav-link fw-semibold site-nav-link" asp-page="/Customer/Catalog"><i class="fas fa-store me-1"></i> Sản phẩm</a>
        </li>
    }
</ul>

<!-- RIGHT NAVIGATION -->
<ul class="navbar-nav align-items-center site-nav-group site-nav-actions">

    @if (!isAuthenticated)
    {
        <li class="nav-item">
            <a class="nav-link fw-semibold site-nav-link" asp-page="/Auth/Login"><i class="fas fa-sign-in-alt me-1"></i> Đăng nhập</a>
        </li>
        <li class="nav-item">
            <a class="nav-link fw-semibold site-nav-button" asp-page="/Auth/Register"><i class="fas fa-user-plus me-1"></i> Đăng ký</a>
        </li>
    }
    else
    {
        <li class="nav-item dropdown ms-2">
            <a class="nav-link fw-semibold position-relative site-nav-button site-nav-cart dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" id="notiBell">
                <i class="fas fa-bell"></i>
                <span class="badge bg-danger position-absolute top-0 start-100 translate-middle rounded-pill" id="notiCount" style="display: @(unreadNotiCount > 0 ? "inline-block" : "none")">@unreadNotiCount</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm site-dropdown-menu" style="width: 320px; max-height: 400px; overflow-y: auto;" id="notiDropdown">
                <li><h6 class="dropdown-header">Thông báo của bạn</h6></li>
                @if (recentNotis.Any())
                {
                    foreach (var noti in recentNotis)
                    {
                        var badgeClass = noti.Type switch { "success" => "bg-success", "warning" => "bg-warning", "danger" => "bg-danger", _ => "bg-primary" };
                        <li>
                            <a class="dropdown-item py-2 border-bottom @(noti.IsRead ? "text-muted" : "fw-bold")" href="#">
                                <div class="d-flex w-100 justify-content-between">
                                    <span class="mb-1 text-truncate" style="max-width: 200px;">@noti.Title</span>
                                    <small class="text-muted" style="font-size: 0.75rem;">@noti.TimeAgo</small>
                                </div>
                                <p class="mb-0 text-wrap text-muted" style="font-size: 0.85rem;">@noti.Message</p>
                            </a>
                        </li>
                    }
                }
                else
                {
                    <li class="text-center p-3 text-muted" id="emptyNoti">Chưa có thông báo nào</li>
                }
            </ul>
        </li>

        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle fw-semibold site-nav-link" href="#" role="button" data-bs-toggle="dropdown">
                <i class="fas fa-user-circle me-1"></i> @userName
                @if (isAdmin)
                {
                    <span class="badge bg-danger ms-1">Admin</span>
                }
                else if (isStaff)
                {
                    <span class="badge bg-warning ms-1">Staff</span>
                }
                else
                {
                    <span class="badge bg-success ms-1">User</span>
                }
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm site-dropdown-menu">
                @if (!isAdmin && !isStaff)
                {
                    <li><a class="dropdown-item" asp-page="/Customer/Profile"><i class="fas fa-user me-2"></i> Hồ sơ cá nhân</a></li>
                    <li><a class="dropdown-item" asp-page="/Customer/MyOrders"><i class="fas fa-receipt me-2"></i> Đơn hàng của tôi</a></li>
                    <li><a class="dropdown-item" asp-page="/Customer/MyShop"><i class="fas fa-store me-2"></i> Shop của tôi</a></li>
                    <li><hr class="dropdown-divider" /></li>
                }
                <li>
                    <form asp-page="/Auth/Logout" method="post" class="px-3 py-1">
                        <button type="submit" class="dropdown-item text-danger">
                            <i class="fas fa-sign-out-alt me-2"></i> Đăng xuất
                        </button>
                    </form>
                </li>
            </ul>
        </li>

        <!-- Only show Cart for normal users -->
        @if (!isAdmin && !isStaff)
        {
            <li class="nav-item ms-2">
                <a class="nav-link fw-semibold position-relative site-nav-button site-nav-cart" asp-page="/Customer/Cart">
                    <i class="fas fa-shopping-cart"></i>
                    @if (cartCount > 0)
                    {
                        <span class="badge bg-danger position-absolute top-0 start-100 translate-middle rounded-pill" id="cartCount">@cartCount</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary position-absolute top-0 start-100 translate-middle rounded-pill" id="cartCount">0</span>
                    }
                </a>
            </li>
        }
    }
</ul>
